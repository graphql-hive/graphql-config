{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2021",
    "lib": ["es2021", "dom"],
    "outDir": "dist",
    "skipLibCheck": false,
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals"],
    "paths": {
      "graphql-config": ["./src/index.ts"]
    }
  }
}
